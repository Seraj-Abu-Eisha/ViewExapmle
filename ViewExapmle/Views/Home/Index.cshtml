@using ViewExapmle.Models
@{
    string appTitle = "Asp.Net Core Demo App";
    Person person = new Person()
            {
                name = "John",
                DateOfBirth =
            Convert.ToDateTime(2000 - 07 - 01)
            };
}
<!DOCTYPE html>
<html>
    <head>
        <title>@appTitle</title>
        <meta charset="utf-8" />
    </head>
    <body>
    <h1>Welcome</h1>
    <h2>Hello @person.name</h2>
    @{
        Math.Round((DateTime.Now - person.DateOfBirth).TotalDays / 365.25);
    }
    </body>
</html>